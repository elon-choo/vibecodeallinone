# Claude Code Power Pack - Environment Configuration
# Copy this file to ~/.claude/power-pack.env and fill in your keys

# === Neo4j (Required for Tier 2+) ===
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your-neo4j-password

# === Gemini (Required for KG LLM features) ===
# Get free key at: https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key

# === Voyage AI (Optional - for code embeddings) ===
# Get key at: https://dash.voyageai.com/
# Without this, keyword search still works (no vector search)
VOYAGE_API_KEY=your-voyage-api-key

# === OpenAI (Optional - fallback embeddings) ===
OPENAI_API_KEY=your-openai-api-key

# === KG MCP Server Path (auto-detected if not set) ===
# KG_MCP_ROOT=/path/to/kg-mcp-server
