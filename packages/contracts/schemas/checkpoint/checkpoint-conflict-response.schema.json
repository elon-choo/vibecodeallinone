{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://claude-code-power-pack.local/contracts/checkpoint/checkpoint-conflict-response.schema.json",
  "title": "CheckpointConflictResponse",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "code",
    "message",
    "server_checkpoint",
    "client_checkpoint"
  ],
  "properties": {
    "code": {
      "type": "string",
      "const": "checkpoint_conflict"
    },
    "message": {
      "type": "string",
      "minLength": 1
    },
    "server_checkpoint": {
      "$ref": "./session-checkpoint.schema.json"
    },
    "client_checkpoint": {
      "$ref": "./session-checkpoint.schema.json"
    }
  }
}
