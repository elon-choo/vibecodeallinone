{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://claude-code-power-pack.local/contracts/auth/openai-start-response.schema.json",
  "title": "OpenAiStartResponse",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "authorization_url",
    "state",
    "provider"
  ],
  "properties": {
    "authorization_url": {
      "type": "string",
      "format": "uri"
    },
    "state": {
      "type": "string",
      "minLength": 8
    },
    "provider": {
      "type": "string",
      "const": "openai"
    }
  }
}
