{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://claude-code-power-pack.local/contracts/reminders/reminder-follow-up-policy.schema.json",
  "title": "ReminderFollowUpPolicy",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "on_failure": {
      "type": "string",
      "enum": [
        "none",
        "retry"
      ],
      "default": "none"
    },
    "max_attempts": {
      "type": "integer",
      "minimum": 1,
      "maximum": 10,
      "default": 1
    },
    "retry_delay_seconds": {
      "type": "integer",
      "minimum": 0,
      "maximum": 604800,
      "default": 0
    }
  }
}
