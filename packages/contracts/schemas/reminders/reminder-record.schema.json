{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://claude-code-power-pack.local/contracts/reminders/reminder-record.schema.json",
  "title": "ReminderRecord",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "reminder_id",
    "job_id",
    "user_id",
    "device_session_id",
    "status",
    "channel",
    "scheduled_for",
    "payload",
    "created_at",
    "updated_at",
    "delivered_at",
    "canceled_at",
    "last_error_code",
    "last_error_message"
  ],
  "properties": {
    "reminder_id": {
      "type": "string",
      "minLength": 1
    },
    "job_id": {
      "type": "string",
      "minLength": 1
    },
    "user_id": {
      "type": "string",
      "minLength": 1
    },
    "device_session_id": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": [
        "scheduled",
        "delivered",
        "canceled",
        "failed"
      ]
    },
    "channel": {
      "type": "string",
      "enum": [
        "web",
        "pwa",
        "ios_webview",
        "android_webview",
        "telegram"
      ]
    },
    "scheduled_for": {
      "type": "string",
      "format": "date-time"
    },
    "payload": {
      "type": "object"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    },
    "delivered_at": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "canceled_at": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "last_error_code": {
      "type": [
        "string",
        "null"
      ]
    },
    "last_error_message": {
      "type": [
        "string",
        "null"
      ]
    },
    "follow_up_policy": {
      "$ref": "./reminder-follow-up-policy.schema.json"
    },
    "follow_up_state": {
      "$ref": "./reminder-follow-up-state.schema.json"
    }
  }
}
