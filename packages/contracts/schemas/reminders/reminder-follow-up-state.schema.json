{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://claude-code-power-pack.local/contracts/reminders/reminder-follow-up-state.schema.json",
  "title": "ReminderFollowUpState",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "status": {
      "type": "string",
      "enum": [
        "none",
        "retry_scheduled",
        "snoozed",
        "rescheduled",
        "dead_letter"
      ],
      "default": "none"
    },
    "attempt_count": {
      "type": "integer",
      "minimum": 0,
      "default": 0
    },
    "last_attempt_at": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "next_attempt_at": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "last_transition_at": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "last_transition_reason": {
      "type": [
        "string",
        "null"
      ]
    }
  }
}
