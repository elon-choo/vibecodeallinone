{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://claude-code-power-pack.local/contracts/evidence/evidence-ref.schema.json",
  "title": "EvidenceRef",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "app_version",
    "bundle_id",
    "summary_ref",
    "overall_status",
    "generated_at"
  ],
  "properties": {
    "app_version": {
      "type": "string",
      "minLength": 1
    },
    "bundle_id": {
      "type": "string",
      "minLength": 1
    },
    "summary_ref": {
      "type": "string",
      "minLength": 1
    },
    "overall_status": {
      "type": "string",
      "enum": [
        "not_run",
        "running",
        "pass",
        "warn",
        "fail",
        "blocked",
        "invalid",
        "stale"
      ]
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    }
  }
}
