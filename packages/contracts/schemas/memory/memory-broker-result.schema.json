{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://claude-code-power-pack.local/contracts/memory/memory-broker-result.schema.json",
  "title": "MemoryBrokerResult",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "entry_id",
    "workspace_id",
    "kind",
    "content"
  ],
  "properties": {
    "entry_id": {
      "type": "string",
      "minLength": 1
    },
    "workspace_id": {
      "type": "string",
      "minLength": 1
    },
    "project_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "kind": {
      "type": "string",
      "enum": [
        "document",
        "summary",
        "code",
        "other"
      ]
    },
    "title": {
      "type": [
        "string",
        "null"
      ]
    },
    "content": {
      "type": "string",
      "minLength": 1
    },
    "source_ref": {
      "type": [
        "string",
        "null"
      ]
    },
    "score": {
      "type": [
        "number",
        "null"
      ],
      "minimum": 0,
      "maximum": 1
    }
  }
}
