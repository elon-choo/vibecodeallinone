{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://claude-code-power-pack.local/contracts/memory/memory-source.schema.json",
  "title": "MemorySource",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "memory_id",
    "conversation_id",
    "captured_at"
  ],
  "properties": {
    "memory_id": {
      "type": "string",
      "minLength": 1
    },
    "conversation_id": {
      "type": "string",
      "minLength": 1
    },
    "message_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "note": {
      "type": "string"
    },
    "captured_at": {
      "type": "string",
      "format": "date-time"
    }
  }
}
