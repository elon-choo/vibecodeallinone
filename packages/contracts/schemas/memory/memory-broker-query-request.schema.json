{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://claude-code-power-pack.local/contracts/memory/memory-broker-query-request.schema.json",
  "title": "MemoryBrokerQueryRequest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "query"
  ],
  "properties": {
    "query": {
      "type": "string",
      "minLength": 1
    },
    "project_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "limit": {
      "type": "integer",
      "minimum": 1,
      "maximum": 20,
      "default": 5
    },
    "source_surface": {
      "type": "string",
      "enum": [
        "web",
        "pwa",
        "ios_webview",
        "android_webview",
        "telegram"
      ],
      "default": "web"
    }
  }
}
