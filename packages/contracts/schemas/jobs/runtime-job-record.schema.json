{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://claude-code-power-pack.local/contracts/jobs/runtime-job-record.schema.json",
  "title": "RuntimeJobRecord",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "job_id",
    "user_id",
    "kind",
    "status",
    "requested_at",
    "started_at",
    "completed_at",
    "error_code",
    "error_message",
    "resource_id",
    "audit",
    "details"
  ],
  "properties": {
    "job_id": {
      "type": "string",
      "minLength": 1
    },
    "user_id": {
      "type": "string",
      "minLength": 1
    },
    "kind": {
      "type": "string",
      "enum": [
        "memory_export",
        "memory_delete",
        "reminder_delivery"
      ]
    },
    "status": {
      "type": "string",
      "enum": [
        "queued",
        "running",
        "succeeded",
        "failed",
        "canceled"
      ]
    },
    "requested_at": {
      "type": "string",
      "format": "date-time"
    },
    "available_at": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "started_at": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "completed_at": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "error_code": {
      "type": [
        "string",
        "null"
      ]
    },
    "error_message": {
      "type": [
        "string",
        "null"
      ]
    },
    "resource_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "attempt_count": {
      "type": "integer",
      "minimum": 0
    },
    "audit": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "device_session_id",
        "surface",
        "conversation_id"
      ],
      "properties": {
        "device_session_id": {
          "type": "string",
          "minLength": 1
        },
        "surface": {
          "type": "string",
          "enum": [
            "web",
            "pwa",
            "ios_webview",
            "android_webview",
            "telegram"
          ]
        },
        "conversation_id": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "details": {
      "type": "object"
    }
  }
}
